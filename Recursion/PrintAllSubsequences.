import java.util.*;

public class Main {

    static void printSubsequence(int index, int[] arr, List<Integer> ds) {
        if (index == arr.length) {
            System.out.println(ds);
            return;
        }

        // Take
        ds.add(arr[index]);
        printSubsequence(index + 1, arr, ds);

        // Not Take
        ds.remove(ds.size() - 1);
        printSubsequence(index + 1, arr, ds);
    }

    public static void main(String[] args) {
        int[] arr = {3, 1, 2};
        printSubsequence(0, arr, new ArrayList<>());
    }
}
